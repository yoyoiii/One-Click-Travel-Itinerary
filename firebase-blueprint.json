{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user was created"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Itinerary": {
      "title": "Itinerary",
      "description": "A saved travel itinerary",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who created the itinerary"
        },
        "name": {
          "type": "string",
          "description": "The name of the itinerary"
        },
        "destination": {
          "type": "string",
          "description": "The destination of the trip"
        },
        "arrivalTime": {
          "type": "string",
          "description": "The arrival time"
        },
        "departureTime": {
          "type": "string",
          "description": "The departure time"
        },
        "days": {
          "type": "array",
          "description": "The daily itinerary details"
        },
        "overallRouteSummary": {
          "type": "string",
          "description": "A summary of the overall route"
        },
        "paceWarning": {
          "type": "string",
          "description": "A warning about the pace of the trip, if applicable"
        },
        "cafesAndTea": {
          "type": "array",
          "description": "Recommended cafes and tea shops"
        },
        "bakeriesAndDesserts": {
          "type": "array",
          "description": "Recommended bakeries and dessert shops"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the itinerary was created"
        }
      },
      "required": ["userId", "destination", "arrivalTime", "departureTime", "days", "overallRouteSummary", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/itineraries/{itineraryId}": {
      "schema": {
        "$ref": "#/entities/Itinerary"
      },
      "description": "Stores saved travel itineraries"
    }
  }
}
